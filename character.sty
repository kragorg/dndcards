            & \head{\prop_item:Nn \g_dnd_names_prop {##1}}
        } \\

        \textbf{Score}
        \clist_map_inline:Nn \l_dnd_order_clist {
            & {\boldmath $\prop_item:Nn \g_dnd_stats_prop {##1}$}
        } \\

        \textbf{Modifier}
        \clist_map_inline:Nn \l_dnd_order_clist {
            & {\prop_if_in:NnT \g_dnd_profs_prop {##1} \boldmath $\__dnd_output_modifier:n {##1}$}
        } \\

        \textbf{Save}
        \clist_map_inline:Nn \l_dnd_order_clist {
            & {\prop_if_in:NnT \g_dnd_profs_prop {##1} \boldmath $\__dnd_output_save:n {##1}$}
        }
    \end{tabular}
}

